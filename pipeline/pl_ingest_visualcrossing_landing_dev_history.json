											"value": "@variables('current_date')",
											"type": "Expression"
										},
										"apiKey": {
											"value": "@activity('web_get_apikey').output.value",
											"type": "Expression"
										}
									}
								}
							],
							"outputs": [
								{
									"referenceName": "ds_json_visualcrossing_landing_dev",
									"type": "DatasetReference",
									"parameters": {
										"city": {
											"value": "@pipeline().parameters.city",
											"type": "Expression"
										},
										"date": {
											"value": "@variables('current_date')",
											"type": "Expression"
										},
										"file_name": {
											"value": "@toLower(concat('atmos_', pipeline().parameters.city, '_', formatDateTime(utcNow(), 'yyyyMMddHHmmss'), '.json'))",
											"type": "Expression"
										}
									}
								}
							]
						},
						{
							"name": "adding_data",
							"type": "SetVariable",
							"dependsOn": [
								{
									"activity": "copy_visualcrossing_to_landing",
									"dependencyConditions": [
										"Succeeded"
									]
								}
							],
							"policy": {
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"variableName": "add_data",
								"value": {
									"value": "@formatDateTime(adddays(variables('current_date'), 1), 'yyyy-MM-dd')",
									"type": "Expression"
								}
							}
						},
						{
							"name": "set_current_date_next",
							"type": "SetVariable",
							"dependsOn": [
								{
									"activity": "adding_data",
									"dependencyConditions": [
