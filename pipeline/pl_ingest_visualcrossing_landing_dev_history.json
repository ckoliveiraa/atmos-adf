									]
								}
							],
							"policy": {
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"variableName": "current_date",
								"value": {
									"value": "@variables('add_data')",
									"type": "Expression"
								}
							}
						}
					],
					"timeout": "0.12:00:00"
