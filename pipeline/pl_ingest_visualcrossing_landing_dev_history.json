				"type": "string"
			},
			"startDate": {
				"type": "string"
			},
			"endDate": {
				"type": "string"
			}
		},
		"variables": {
			"date": {
				"type": "String"
			},
			"current_date": {
				"type": "String"
			},
			"add_data": {
				"type": "String"
			}
		},
		"folder": {
			"name": "VisualCrossing"
		},
		"annotations": []
	}
}