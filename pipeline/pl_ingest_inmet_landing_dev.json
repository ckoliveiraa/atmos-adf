{
	"name": "pl_ingest_inmet_landing_dev",
	"properties": {
		"activities": [
			{
				"name": "web_get_apikey",
				"type": "WebActivity",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"method": "GET",
					"url": "https://kv-atmos-dev-westus2-001.vault.azure.net/secrets/visualcrosssing-api-key-dev/9e86faa3450745a0baab70f80a9ce055?api-version=2025-07-01",
					"authentication": {
						"type": "MSI",
						"resource": "https://vault.azure.net/"
					}
				}
			},
			{
				"name": "set_year_list",
				"type": "SetVariable",
				"dependsOn": [
					{
						"activity": "web_get_apikey",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"variableName": "year_list",
					"value": {
						"value": "@range(pipeline().parameters.startYear, add(sub(pipeline().parameters.endYear,pipeline().parameters.startYear),1))",
						"type": "Expression"
					}
				}
			},
			{
				"name": "foreach_ano",
				"type": "ForEach",
				"dependsOn": [
					{
						"activity": "set_year_list",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"userProperties": [],
				"typeProperties": {
					"items": {
						"value": "@variables('year_list')",
						"type": "Expression"
					},
					"isSequential": false,
					"batchCount": 5,
					"activities": [
						{
							"name": "copy_inmet_to_landing",
							"type": "Copy",
							"dependsOn": [],
							"policy": {
								"timeout": "0.12:00:00",
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"source": {
									"type": "GoogleBigQueryV2Source",
									"query": {
										"value": "@concat('SELECT * FROM `basedosdados.br_inmet_bdmep.microdados`\nWHERE id_estacao = ''',pipeline().parameters.id_estacao,''' \n    AND ano = ',string(item()))",
										"type": "Expression"
									}
								},
								"sink": {
									"type": "DelimitedTextSink",
									"storeSettings": {
										"type": "AzureBlobFSWriteSettings"
									},
									"formatSettings": {
										"type": "DelimitedTextWriteSettings",
										"quoteAllText": true,
										"fileExtension": ".txt"
									}
								},
								"enableStaging": false,
								"translator": {
									"type": "TabularTranslator",
									"typeConversion": true,
									"typeConversionSettings": {
										"allowDataTruncation": true,
										"treatBooleanAsNumber": false
									}
								}
							},
							"inputs": [
								{
									"referenceName": "ds_bigquey_inmet_src_dev",
									"type": "DatasetReference",
									"parameters": {
										"id_estacao": {
											"value": "@pipeline().parameters.id_estacao",
											"type": "Expression"
										},
										"ano": {
											"value": "@item()",
											"type": "Expression"
										}
									}
								}
							],
							"outputs": [
								{
									"referenceName": "ds_csv_inmet_landing_dev",
									"type": "DatasetReference",
									"parameters": {
										"ano": {
											"value": "@item()",
											"type": "Expression"
										}
									}
								}
							]
						}
					]
				}
			}
		],
		"parameters": {
			"id_estacao": {
				"type": "string"
			},
			"startYear": {
				"type": "int"
			},
			"endYear": {
				"type": "int"
			}
		},
		"variables": {
			"year_list": {
				"type": "Array"
			}
		},
		"folder": {
			"name": "INMET"
		},
		"annotations": []
	}
}